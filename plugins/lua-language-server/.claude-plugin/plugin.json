{
  "name": "lua-language-server",
  "version": "1.0.0",
  "language": "lua",
  "displayName": "Lua",
  "description": "Lua LSP server — diagnostics, completions, hover, and built-in Neovim/LÖVE 2D runtime awareness.",
  "author": { "name": "0xankit" },
  "binary": "lua-language-server",
  "extensions": [
    ".lua"
  ],
  "install": {
    "brew (recommended)": "brew install lua-language-server",
    "scoop (Windows)": "scoop install lua-language-server"
  },
  "homepage": "https://luals.github.io",
  "repository": "https://github.com/LuaLS/lua-language-server",
  "license": "MIT",
  "keywords": [
    "lua",
    "lsp",
    "language-server"
  ],
  "lspServers": "./.lsp.json"
}
