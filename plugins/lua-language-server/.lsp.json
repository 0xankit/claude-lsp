{
  "lua": {
    "command": "lua-language-server",
    "args": [],
    "extensionToLanguage": {
      ".lua": "lua"
    },
    "transport": "stdio",
    "initializationOptions": {},
    "settings": {
      "Lua": {
        "runtime": {
          "version": "LuaJIT"
        },
        "diagnostics": {
          "globals": ["vim"]
        },
        "workspace": {
          "checkThirdParty": false
        },
        "telemetry": {
          "enable": false
        }
      }
    },
    "startupTimeout": 15000,
    "restartOnCrash": true,
    "maxRestarts": 3
  }
}
