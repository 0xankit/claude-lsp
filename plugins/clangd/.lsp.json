{
  "c-cpp": {
    "command": "clangd",
    "args": [
      "--background-index",
      "--clang-tidy",
      "--completion-style=detailed"
    ],
    "extensionToLanguage": {
      ".c": "c",
      ".h": "c",
      ".cpp": "cpp",
      ".cc": "cpp",
      ".cxx": "cpp",
      ".hpp": "cpp",
      ".hxx": "cpp"
    },
    "transport": "stdio",
    "initializationOptions": {},
    "settings": {},
    "startupTimeout": 20000,
    "restartOnCrash": true,
    "maxRestarts": 3
  }
}
