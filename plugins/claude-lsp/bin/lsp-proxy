#!/usr/bin/env bash
# lsp-proxy — thin wrapper called by Claude Code for each entry in .lsp.json.
# Usage: lsp-proxy <language-key> <binary> [binary-args...]
#
# The language-key arg is consumed here; only enabled languages appear in the
# .lsp.json generated by scripts/gen-lsp.py, so no filtering is needed.

set -euo pipefail

shift  # drop the language-key arg
exec "$@"
