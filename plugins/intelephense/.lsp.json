{
  "php": {
    "command": "intelephense",
    "args": [
      "--stdio"
    ],
    "extensionToLanguage": {
      ".php": "php",
      ".phtml": "php"
    },
    "transport": "stdio",
    "initializationOptions": {
      "storagePath": "${CLAUDE_PLUGIN_DATA}/intelephense"
    },
    "settings": {
      "intelephense": {
        "files": {
          "maxSize": 5000000
        },
        "diagnostics": {
          "enable": true
        }
      }
    },
    "startupTimeout": 20000,
    "restartOnCrash": true,
    "maxRestarts": 3
  }
}
