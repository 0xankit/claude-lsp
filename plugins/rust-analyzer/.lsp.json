{
  "rust": {
    "command": "rust-analyzer",
    "args": [],
    "extensionToLanguage": {
      ".rs": "rust"
    },
    "transport": "stdio",
    "initializationOptions": {},
    "settings": {
      "rust-analyzer": {
        "checkOnSave": {
          "command": "clippy"
        },
        "inlayHints": {
          "enable": true
        }
      }
    },
    "startupTimeout": 30000,
    "restartOnCrash": true,
    "maxRestarts": 3
  }
}
