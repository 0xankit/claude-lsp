{
  "name": "gopls",
  "version": "1.0.0",
  "language": "go",
  "displayName": "Go",
  "description": "Official Go language server maintained by the Go team — completions, navigation, diagnostics, and static analysis.",
  "author": { "name": "0xankit" },
  "binary": "gopls",
  "extensions": [
    ".go"
  ],
  "install": {
    "go (recommended)": "go install golang.org/x/tools/gopls@latest",
    "brew": "brew install gopls"
  },
  "homepage": "https://pkg.go.dev/golang.org/x/tools/gopls",
  "repository": "https://github.com/golang/tools/tree/master/gopls",
  "license": "BSD-3-Clause",
  "keywords": [
    "go",
    "golang",
    "lsp",
    "language-server"
  ],
  "lspServers": "./.lsp.json"
}
