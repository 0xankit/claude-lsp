{
  "$schema": "https://json.schemastore.org/claude-code-marketplace.json",
  "name": "claude-lsp",
  "version": "1.0.0",
  "description": "Ready-to-use LSP configuration templates for Claude Code. Each language is a standalone plugin — install only what your project needs.",
  "owner": {
    "name": "0xankit",
    "email": "ankit.kr554@gmail.com",
    "url": "https://github.com/0xankit"
  },
  "plugins": [
    {
      "name": "lsp-rust-analyzer",
      "description": "Official Rust language server — completions, inlay hints, refactoring, and clippy integration.",
      "author": { "name": "0xankit" },
      "homepage": "https://rust-analyzer.github.io",
      "repository": "https://github.com/rust-lang/rust-analyzer",
      "license": "Apache-2.0 OR MIT",
      "keywords": ["rust", "lsp", "language-server"],
      "category": "language-support",
      "source": {
        "source": "git-subdir",
        "url": "https://github.com/0xankit/claude-lsp",
        "path": "plugins/rust-analyzer"
      }
    },
    {
      "name": "lsp-gopls",
      "description": "Official Go language server maintained by the Go team — completions, navigation, diagnostics, and static analysis.",
