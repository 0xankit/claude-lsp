{
  "html": {
    "command": "vscode-html-language-server",
    "args": ["--stdio"],
    "extensionToLanguage": {
      ".html": "html",
      ".htm": "html",
      ".xhtml": "html"
    },
    "transport": "stdio",
    "initializationOptions": {},
    "settings": {
      "html": {
        "format": { "enable": true },
        "suggest": { "html5": true }
      }
    },
    "startupTimeout": 10000,
    "restartOnCrash": true,
    "maxRestarts": 3
  }
}
