{
  "python": {
    "command": "pylsp",
    "args": [],
    "extensionToLanguage": {
      ".py": "python",
      ".pyw": "python",
      ".pyi": "python"
    },
    "transport": "stdio",
    "initializationOptions": {},
    "settings": {
      "pylsp": {
        "plugins": {
          "pyflakes": { "enabled": true },
          "pycodestyle": { "enabled": true },
          "pylsp_mypy": { "enabled": false },
          "autopep8": { "enabled": false },
          "yapf": { "enabled": false }
        }
      }
    },
    "startupTimeout": 15000,
    "restartOnCrash": true,
    "maxRestarts": 3
  }
}
