{
  "name": "pylsp",
  "language": "python",
  "displayName": "Python",
  "description": "Python LSP server — diagnostics via pyflakes/pycodestyle, completions, hover, and optional mypy/rope plugins.",
  "binary": "pylsp",
  "extensions": [
    ".py",
    ".pyw",
    ".pyi"
  ],
  "install": {
    "pip (recommended)": "pip install python-lsp-server",
    "pip (all plugins)": "pip install 'python-lsp-server[all]'",
    "pipx": "pipx install python-lsp-server",
    "brew": "brew install python-lsp-server"
  },
  "alternatives": {
    "pyright": {
      "install": "npm install -g pyright",
      "note": "Microsoft's strict type-checker; faster and more opinionated than pylsp."
    },
    "basedpyright": {
      "install": "npm install -g basedpyright",
      "note": "Community fork of pyright with extra features."
    }
  },
  "homepage": "https://github.com/python-lsp/python-lsp-server",
  "repository": "https://github.com/python-lsp/python-lsp-server",
  "license": "MIT",
  "keywords": [
    "python",
    "lsp",
    "language-server"
  ],
  "lspServers": "./.lsp.json"
}
